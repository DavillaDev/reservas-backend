// api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// 1. USUÁRIOS (QUEM LOGA NO SISTEMA: ADMIN/STAFF)
// =========================================================
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   // Senha Hasheada (Bcrypt)
  name        String
  
  // Controle de Acesso
  role        UserRole @default(STAFF)
  
  // Vínculo: A qual balada esse usuário pertence?
  nightclubId String?
  nightclub   Nightclub? @relation(fields: [nightclubId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// =========================================================
// 2. A BALADA (O CLIENTE QUE TE PAGA)
// =========================================================
model Nightclub {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?  
  mapUrl      String?  
  themeColor  String?  @default("#697cafff")
  whatsapp    String
  vipTokens    VipToken[]
  
  // SAAS & FINANCEIRO
  appFeePercent Decimal @default(5.0) 
  
  // Token do Mercado Pago DELES
  mpAccessToken String? 

  repassPixKey     String?
  repassPixKeyType String? // e.g., 'CPF', 'CNPJ', 'EMAIL', 'PHONE', 'EVP'
  
  // Configurações visuais e regras gerais
  settings     Json?     

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  users        User[]        
  spaces       Space[]
  reservations Reservation[]

  @@map("nightclubs")
}

// =========================================================
// 3. O INVENTÁRIO (MESAS/CAMAROTES)
// =========================================================
model Space {
  id             String      @id @default(uuid())
  nightclubId    String
  name           String
  type           SpaceType
  capacity       Int
  status         SpaceStatus @default(ACTIVE)
  
  price          Decimal?    @default(0.0)
  minConsumption Decimal?    @default(0.0)

  description    String?
  mapPosition    Json?        

  nightclub    Nightclub   @relation(fields: [nightclubId], references: [id])
  reservations Reservation[]

  @@map("spaces")
}

// =========================================================
// 4. O CLIENTE (NOVO! BASE PARA O CRM E BLACKLIST)
// =========================================================
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  cpf       String?  @unique // CPF único para garantir o bloqueio real
  birthdayDate DateTime?
  
  // 🚨 O Campo da Discórdia: Se true, o cliente não consegue reservar
  isBlocked Boolean  @default(false)
  
  reservations Reservation[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

// =========================================================
// 5. AS RESERVAS (ATUALIZADO COM RELAÇÃO AO CLIENTE)
// =========================================================
model Reservation {
  id            String            @id @default(uuid())
  nightclubId   String
  spaceId       String
  date          DateTime          @db.Date
  
  // Dados Snapshots (Mantidos para histórico visual rápido)
  customerName  String
  customerPhone String
  customerEmail String?            
  
  // 🔗 VÍNCULO NOVO: Liga a reserva ao perfil único do cliente
  customerId    String?           
  customer      Customer?         @relation(fields: [customerId], references: [id])
  
  isBirthday    Boolean           @default(false) 
  birthdayDate  DateTime?         
  notes         String?            

  status        ReservationStatus @default(PENDING)
  checkInTime   DateTime?
  checkInAt     DateTime? // Mantive o seu original caso use em outro lugar
  validationToken String? @unique

  // FINANCEIRO
  amount           Decimal?   @default(0.0)
  paymentId        String?    @unique 
  paymentCreatedAt DateTime?
  paymentDeadline  DateTime?
  
  createdAt      DateTime          @default(now())

  nightclub Nightclub @relation(fields: [nightclubId], references: [id])
  space     Space     @relation(fields: [spaceId], references: [id])

  @@map("reservations")
}

// =========================================================
// 6. LISTA VIP (TOKENS GERADOS PELO DONO)
// =========================================================
model VipToken {
  id           String      @id @default(uuid())
  nightclubId  String
  code         String      @unique // Ex: VIP-XJ92 (O "Passaporte" da Lista)
  
  maxGuests    Int         @default(50) // Limite de nomes por esse código
  currentCount Int         @default(0)
  
  expiresAt    DateTime    // Quando o código para de aceitar novos nomes
  isActive     Boolean     @default(true)
  
  // Relações
  guests       VipGuest[]
  nightclub    Nightclub   @relation(fields: [nightclubId], references: [id])
  createdAt    DateTime    @default(now())

  @@map("vip_tokens")
}

// =========================================================
// 7. CONVIDADOS DA LISTA VIP (OS NOMES NA LISTA)
// =========================================================
model VipGuest {
  id           String      @id @default(uuid())
  vipTokenId   String
  
  name         String
  phone        String?

  validationToken String?        @unique
  
  status       VipGuestStatus @default(PENDING)
  checkInAt    DateTime?
  
  vipToken     VipToken    @relation(fields: [vipTokenId], references: [id])
  createdAt    DateTime    @default(now())

  @@map("vip_guests")
}

// =========================================================
// ENUMS
// =========================================================

enum UserRole {
  SUPERADMIN 
  OWNER      
  STAFF      
}

enum SpaceType {
  CAMAROTE
  BISTRO
  MESA
}

enum SpaceStatus {
  ACTIVE
  MAINTENANCE
  DISABLED
}

enum ReservationStatus {
  PENDING    
  CONFIRMED  
  CANCELED   
  COMPLETED  
  CHECKED_IN
  NO_SHOW     // 🚨 NOVO: Cliente reservou e não apareceu (Gatilho para banimento)
}

enum VipGuestStatus {
  PENDING      // Nome na lista, mas não chegou
  CHECKED_IN   // Já entrou na casa
  CANCELLED    // Removido da lista
}